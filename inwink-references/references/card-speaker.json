{
  "meta": {
    "id": "card-speaker",
    "label": "Card Speaker",
    "description": "Gabarit de card pour les intervenants (speakers) d'un événement Inwink.",
    "version": "1.0",
    "status": "à valider"
  },

  "dom": {
    "structure": {
      "tag": "div",
      "classes": ["inwink-item", "speaker-item"],
      "children": [
        {
          "tag": "a",
          "classes": ["itemcontent", "clickable", "card"],
          "conditionalClasses": {
            "round": "Ajoutée si templateOptions.roundPicture === true"
          },
          "note": "C'est la card elle-même — un lien <a>, pas un div",
          "children": [
            {
              "tag": "div",
              "classes": ["userpicture", "userpictureimg"],
              "note": "Bloc photo. Contient toujours les deux enfants, la photo passe par-dessus les initiales.",
              "children": [
                {
                  "tag": "div",
                  "classes": ["userpicture-text"],
                  "note": "Fallback initiales — toujours présent dans le DOM, masqué visuellement par la photo",
                  "children": [
                    {
                      "tag": "span",
                      "classes": ["text"],
                      "content": "Initiales ex: PM",
                      "source": "firstname[0] + lastname[0]"
                    }
                  ]
                },
                {
                  "tag": "img",
                  "classes": ["userpicture-photo"],
                  "source": "photo.thumbUrl",
                  "note": "Photo réelle du speaker"
                }
              ]
            },
            {
              "tag": "div",
              "classes": ["detail"],
              "children": [
                {
                  "tag": "h4",
                  "classes": ["name", "bloc-accent"],
                  "note": "Utilise --inwinkaccentcolor. Toujours présent.",
                  "fields": ["firstname", "lastname"],
                  "structure": "span.fieldval > span.fieldtext par champ, séparés par un span espace"
                },
                {
                  "tag": "h5",
                  "classes": ["company"],
                  "note": "Masqué si templateOptions.hideCompany === true ou champ vide",
                  "fields": ["company"],
                  "maxLength": 30,
                  "showIf": "company non vide ET hideCompany !== true"
                },
                {
                  "tag": "h5",
                  "classes": ["jobTitle"],
                  "note": "Masqué si templateOptions.hideJobtitle === true ou champ vide",
                  "fields": ["jobTitle"],
                  "maxLength": 30,
                  "showIf": "jobTitle non vide ET hideJobtitle !== true"
                }
              ]
            },
            {
              "tag": "div",
              "classes": ["sociallinks"],
              "note": "Toujours présent dans le DOM, vide si pas de réseaux. Masqué si hideSocialLinks === true.",
              "showIf": "hideSocialLinks !== true"
            }
          ]
        }
      ]
    }
  },

  "backoffice": {
    "note": "Champs appelés depuis le back-office Inwink",
    "fields": [
      { "name": "photo.thumbUrl", "label": "Photo (miniature)", "type": "image" },
      { "name": "firstname", "label": "Prénom", "type": "string" },
      { "name": "lastname", "label": "Nom", "type": "string" },
      { "name": "company", "label": "Entreprise", "type": "string", "maxLength": 30 },
      { "name": "jobTitle", "label": "Fonction", "type": "string", "maxLength": 30 }
    ]
  },

  "templateOptions": {
    "note": "Options configurables dans l'interface Inwink — chaque option peut modifier le DOM ou le comportement",
    "options": [
      {
        "key": "roundPicture",
        "type": "bool",
        "default": true,
        "label_fr": "Image arrondie",
        "label_en": "Round picture",
        "effect": "Ajoute la classe CSS 'round' sur l'élément a.card"
      },
      {
        "key": "hideCompany",
        "type": "bool",
        "default": false,
        "label_fr": "Masquer la société",
        "label_en": "Hide person's company name",
        "effect": "Masque le h5.company"
      },
      {
        "key": "hideJobtitle",
        "type": "bool",
        "default": false,
        "label_fr": "Masquer la fonction",
        "label_en": "Hide person's job title",
        "effect": "Masque le h5.jobTitle"
      },
      {
        "key": "hideSocialLinks",
        "type": "bool",
        "default": false,
        "label_fr": "Masquer les réseaux sociaux",
        "label_en": "Hide person's social links",
        "effect": "Masque le bloc .sociallinks"
      }
    ]
  },

  "layout": {
    "note": "Nombre de colonnes selon breakpoint. Inwink ajoute une classe sur l'élément racine (.root-vstate-L pour desktop).",
    "breakpoints": {
      "XXS": "col1",
      "XS": "col2",
      "S": "col3",
      "M": "col3",
      "L": "col5",
      "XL": "col5"
    },
    "rootClasses": {
      "desktop": "root-vstate-L",
      "note": "Classe ajoutée sur l'élément racine de la page en mode desktop"
    },
    "layoutClasses": {
      "note": "Classes ajoutées sur le conteneur du bloc selon le nombre de colonnes",
      "values": ["layout-col1", "layout-col2", "layout-col3", "layout-col4", "layout-col5"]
    }
  },

  "cssScoping": {
    "note": "##contentid est un placeholder remplacé dynamiquement par Inwink avec l'ID réel du bloc. Toujours utiliser ##contentid pour scoper le CSS au bloc concerné.",
    "example": "##contentid .card { ... }"
  },

  "defaultCSS": {
    "note": "CSS embarqué par défaut dans ce gabarit. Ne pas dupliquer dans le CSS personnalisé.",
    "rules": [
      "##contentid .card → display:flex, flex-flow:column nowrap, align-items:center, height:100%, border:0, padding:0, background-color:transparent",
      "##contentid .card .userpicture → margin-top:0",
      "##contentid .card .userpicture, ##contentid .card:not(.round) .userpicture :is(.userpicture-photo, .userpicture-text) → border-radius:0",
      ".root-vstate-L ##contentid .card .userpicture → width:70%, padding-top:70%",
      ".root-vstate-L ##contentid .layout-col3 .card .userpicture → width:60%, padding-top:60%",
      ".root-vstate-L ##contentid .layout-col2 .card .userpicture → width:50%, padding-top:50%",
      ".root-vstate-L ##contentid .layout-col1 .card .userpicture → width:30%, padding-top:30%",
      "##contentid .card .detail → display:flex, flex-direction:column, gap:0.5rem, text-align:center, margin-bottom:1rem, padding:0 10px",
      "##contentid .card .detail :is(h4, h5) → margin:0",
      "##contentid .card .sociallinks .sociallink .icon → width:25px, height:25px, line-height:25px"
    ]
  },

  "inwinkVariables": {
    "note": "Variables CSS Inwink disponibles sur les éléments de ce gabarit. Déclarées sur .bloctheme-* et redéclarées sur .card.",
    "onBloc": [
      "--inwinkbgcolor",
      "--inwinktextcolor",
      "--inwinkaccentcolor",
      "--inwinkaccentbgcolor",
      "--inwinkaccentbgtextcolor",
      "--inwinklightbgcolor",
      "--inwinklightbgtextcolor",
      "--inwinkdarkaccentbgcolor",
      "--inwinkdarkaccentbgtextcolor"
    ],
    "onCard": [
      "--inwinkbgcolor (redéclarée : fond blanc dans blocs sombres)",
      "--inwinktextcolor (redéclarée : texte noir dans blocs sombres)"
    ],
    "usage": {
      "h4.name.bloc-accent": "color: var(--inwinkaccentcolor)",
      "card background": "background-color: var(--inwinkbgcolor)",
      "card text": "color: var(--inwinktextcolor)"
    }
  }
}
